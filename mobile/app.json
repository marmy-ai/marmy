{
  "expo": {
    "name": "Marmy",
    "slug": "marmy",
    "version": "0.1.0",
    "orientation": "default",
    "scheme": "marmy",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.marmy.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Marmy needs microphone access for voice mode to talk with your terminal sessions.",
        "NSLocalNetworkUsageDescription": "Marmy needs local network access to connect to your development machines.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "package": "com.marmy.app",
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset",
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ]
    ]
  }
}
