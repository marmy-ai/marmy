<section class="py-24 sm:py-32 px-5 sm:px-8 section-divide">
  <div class="max-w-5xl mx-auto">
    <div class="flex flex-col lg:flex-row items-center gap-14 lg:gap-20">
      <!-- Copy -->
      <div class="flex-1">
        <div class="font-mono text-xs text-secondary mb-3 tracking-widest reveal">VOICE COMMANDS</div>
        <h2 class="text-2xl sm:text-3xl font-bold mb-5 tracking-[-0.02em] reveal stagger-1">
          Talk to your agents.
        </h2>
        <p class="text-text-secondary mb-4 text-[15px] leading-relaxed reveal stagger-2">
          Real-time bidirectional voice. A Gemini-powered voice agent sits between you and Claude Code. It summarizes what's happening, relays your spoken instructions, and gets approval before sending anything.
        </p>
        <p class="text-text-secondary mb-8 text-[15px] leading-relaxed reveal stagger-3">
          No typing, no screen. You're hands-free. Walk the dog and redirect an agent that's gone off track. This isn't speech-to-text in a chat box. It's a live voice call with your engineering team.
        </p>

        <div class="space-y-4 text-[15px] reveal stagger-4">
          <div class="flex gap-3 items-start">
            <span class="text-secondary font-mono text-xs mt-1 shrink-0">1</span>
            <p class="text-text-secondary italic">"Claude finished the login form and is asking whether to support email-only or also phone number."</p>
          </div>
          <div class="flex gap-3 items-start">
            <span class="text-secondary font-mono text-xs mt-1 shrink-0">2</span>
            <p class="text-text-primary">"Email only for now."</p>
          </div>
          <div class="flex gap-3 items-start">
            <span class="text-secondary font-mono text-xs mt-1 shrink-0">3</span>
            <p class="text-text-secondary">An approval card appears on screen. Tap approve and the instruction is sent.</p>
          </div>
        </div>
      </div>

      <!-- Phone mockup -->
      <div class="flex-shrink-0 reveal stagger-5">
        <div class="relative" style="animation: float 6s ease-in-out infinite; animation-delay: 1s;">
          <div class="absolute inset-0 scale-90 bg-primary/6 rounded-[3rem] blur-[40px]"></div>
          <div class="relative w-[260px] sm:w-[280px] rounded-[2.5rem] border border-border bg-bg-card p-2 shadow-2xl shadow-black/40">
            <div class="flex items-center justify-between px-5 py-1.5">
              <span class="text-[10px] text-text-tertiary font-mono">9:41</span>
              <div class="w-20 h-5 rounded-full bg-bg-deep"></div>
              <span class="text-[10px] text-primary font-mono">2:34</span>
            </div>

            <div class="rounded-2xl bg-bg-deep overflow-hidden">
              <div class="px-4 py-2.5 border-b border-border">
                <div class="flex items-center gap-2">
                  <div class="w-2 h-2 rounded-full bg-voice" style="animation: pulse-soft 1.5s infinite;"></div>
                  <span class="text-xs font-mono text-voice">Voice Call</span>
                </div>
                <span class="text-[10px] font-mono text-text-tertiary mt-0.5 block">frontend-ui</span>
              </div>

              <!-- Transcript -->
              <div class="p-3 space-y-2.5 text-[11px] font-mono min-h-[120px]">
                <div>
                  <span class="text-text-tertiary">assistant:</span>
                  <p class="text-text-secondary mt-0.5">Finished the login form. Email-only or also phone number?</p>
                </div>
                <div>
                  <span class="text-voice">you:</span>
                  <p class="text-text-primary mt-0.5">Email only for now.</p>
                </div>
              </div>

              <!-- Approval card -->
              <div class="mx-3 mb-3 p-2.5 rounded-lg bg-primary/8 border border-primary/20">
                <p class="text-[10px] text-text-tertiary mb-1.5">Send to Claude:</p>
                <p class="text-[11px] text-text-primary font-mono mb-2.5">"Use email-only for the login form."</p>
                <div class="flex gap-2">
                  <button class="flex-1 py-1.5 rounded-md bg-primary text-white text-[10px] font-bold">Approve</button>
                  <button class="flex-1 py-1.5 rounded-md border border-border text-text-secondary text-[10px]">Edit</button>
                </div>
              </div>

              <!-- Waveform -->
              <div class="px-4 py-2.5 border-t border-border flex items-center justify-center gap-[3px]">
                {[3,5,8,12,8,14,10,7,12,16,10,8,5,9,13,8,5,3].map((h) => (
                  <div class="w-[2px] rounded-full bg-voice/50" style={`height: ${h}px; animation: pulse-soft ${1 + Math.random()}s infinite;`}></div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
