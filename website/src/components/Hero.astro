<section class="relative pt-32 pb-24 sm:pt-40 sm:pb-32 px-5 sm:px-8 overflow-hidden noise">
  <!-- Background gradient -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[500px] bg-accent/5 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 right-0 w-[400px] h-[300px] bg-accent/3 rounded-full blur-[100px]"></div>
  </div>

  <div class="relative z-10 max-w-5xl mx-auto">
    <!-- Eyebrow -->
    <div class="flex items-center gap-3 mb-8 reveal">
      <div class="w-2 h-2 rounded-full bg-accent animate-pulse"></div>
      <span class="font-mono text-xs text-text-muted uppercase tracking-widest">Open source &middot; iOS &middot; macOS</span>
    </div>

    <!-- Headline -->
    <h1 class="reveal stagger-1">
      <span class="block font-display text-5xl sm:text-6xl lg:text-7xl xl:text-8xl italic leading-[1.05] tracking-tight">
        Leave your desk.
      </span>
      <span class="block font-display text-5xl sm:text-6xl lg:text-7xl xl:text-8xl italic leading-[1.05] tracking-tight mt-1 sm:mt-2">
        Keep <span class="text-gradient">supervising.</span>
      </span>
    </h1>

    <!-- Subhead -->
    <p class="mt-8 text-lg sm:text-xl text-text-secondary max-w-2xl leading-relaxed reveal stagger-2">
      Marmy is a mobile app for developers who run coding agents. See the actual artifacts your agents produce&mdash;code, docs, images&mdash;from your phone. Check in by voice while you run. Get notified when they need you. No cloud, no infrastructure.
    </p>

    <!-- CTAs -->
    <div class="mt-10 flex flex-col sm:flex-row gap-3 reveal stagger-3">
      <a
        href="#get-started"
        class="inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-lg bg-accent hover:bg-accent-hover text-bg-deep font-semibold transition-all hover:shadow-lg hover:shadow-accent/20"
      >
        Get Started
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
      </a>
      <a
        href="https://github.com/marmy-ai/marmy"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-lg border border-border text-text-primary hover:bg-bg-card transition-all"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
        View Source
      </a>
    </div>

    <!-- Phone mockup -->
    <div class="mt-16 sm:mt-20 flex justify-center reveal stagger-4">
      <div class="relative">
        <!-- Glow behind phone -->
        <div class="absolute inset-0 scale-90 bg-accent/8 rounded-[3rem] blur-[40px]"></div>

        <div class="relative w-[280px] sm:w-[320px] rounded-[2.5rem] border border-border bg-bg-card p-2.5 shadow-2xl" style="animation: float 6s ease-in-out infinite;">
          <!-- Notch -->
          <div class="flex items-center justify-between px-5 py-2">
            <span class="text-[10px] text-text-muted font-mono">9:41</span>
            <div class="w-20 h-5 rounded-full bg-bg-deep"></div>
            <div class="flex gap-1 items-center">
              <div class="w-1.5 h-1.5 rounded-full bg-accent"></div>
              <span class="text-[10px] text-text-muted">LAN</span>
            </div>
          </div>

          <!-- Screen -->
          <div class="rounded-2xl bg-bg-deep overflow-hidden border border-border-subtle">
            <!-- App header -->
            <div class="px-3 py-2 border-b border-border flex items-center justify-between">
              <span class="text-xs font-mono font-semibold text-text-primary">Workers</span>
              <span class="text-[10px] font-mono text-text-muted">mbp-studio</span>
            </div>

            <!-- Session list -->
            <div class="p-2 space-y-1.5 font-mono text-[11px]">
              <!-- Manager -->
              <div class="px-2.5 py-2 rounded-lg bg-accent/8 border border-accent/20">
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-1.5">
                    <span class="text-[9px] px-1 py-0.5 rounded bg-accent/20 text-accent font-bold">MGR</span>
                    <span class="text-accent">ralph</span>
                  </div>
                  <div class="w-1.5 h-1.5 rounded-full bg-accent" style="animation: pulse-soft 2s infinite;"></div>
                </div>
                <div class="text-text-muted text-[10px] mt-1">Monitoring 3 workers...</div>
              </div>

              <!-- Worker 1 -->
              <div class="px-2.5 py-2 rounded-lg bg-bg-card border border-border">
                <div class="flex items-center justify-between">
                  <span class="text-text-primary">auth-refactor</span>
                  <div class="w-1.5 h-1.5 rounded-full bg-green"></div>
                </div>
                <div class="text-text-muted text-[10px] mt-0.5">Migrating session tokens</div>
              </div>

              <!-- Worker 2 -->
              <div class="px-2.5 py-2 rounded-lg bg-bg-card border border-border">
                <div class="flex items-center justify-between">
                  <span class="text-text-primary">api-tests</span>
                  <div class="w-1.5 h-1.5 rounded-full bg-green"></div>
                </div>
                <div class="text-text-muted text-[10px] mt-0.5">Writing integration tests</div>
              </div>

              <!-- Worker 3 -->
              <div class="px-2.5 py-2 rounded-lg bg-bg-card border border-amber/40">
                <div class="flex items-center justify-between">
                  <span class="text-text-primary">frontend-ui</span>
                  <div class="w-1.5 h-1.5 rounded-full bg-amber"></div>
                </div>
                <div class="text-amber text-[10px] mt-0.5">Needs your input</div>
              </div>
            </div>

            <!-- Bottom nav -->
            <div class="flex justify-around py-2 border-t border-border text-[10px] font-mono">
              <span class="text-text-muted">Machines</span>
              <span class="text-accent">Workers</span>
              <span class="text-text-muted">Terminal</span>
              <span class="text-text-muted">Files</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
