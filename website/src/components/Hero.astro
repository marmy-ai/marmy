<script>
  const phrases = [
    "like a boss.",
    "from your phone.",
    "while you sleep.",
    "from anywhere.",
    "without the chaos.",
  ];
  let index = 0;
  const el = document.getElementById("rotating-text");
  if (el) {
    setInterval(() => {
      el.style.opacity = "0";
      el.style.transform = "translateY(8px)";
      setTimeout(() => {
        index = (index + 1) % phrases.length;
        el.textContent = phrases[index];
        el.style.opacity = "1";
        el.style.transform = "translateY(0)";
      }, 300);
    }, 2500);
  }
</script>
