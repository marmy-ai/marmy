<section class="relative pt-28 pb-24 sm:pt-40 sm:pb-32 px-5 sm:px-8 overflow-hidden">
  <!-- Glow -->
  <div class="absolute top-16 left-1/2 -translate-x-1/2 w-[700px] h-[350px] bg-primary/6 rounded-full blur-[140px] pointer-events-none"></div>
  <div class="absolute top-40 left-1/4 w-[300px] h-[200px] bg-manager/4 rounded-full blur-[100px] pointer-events-none"></div>

  <div class="relative z-10 max-w-5xl mx-auto text-left sm:text-center">
    <p class="font-mono text-xs sm:text-sm text-primary tracking-wider mb-5 reveal">THE MOBILE IDE FOR AI AGENTS</p>

    <h1 class="text-4xl sm:text-5xl lg:text-[3.5rem] font-extrabold tracking-[-0.03em] leading-[1.08] mb-6 reveal stagger-1">
      You are the tech lead.<br/>
      Your agents are your <span class="text-primary" id="rotating-word">team.</span>
    </h1>

    <script>
      const words = ["team.", "fleet.", "workforce.", "engineers."];
      let idx = 0;
      const el = document.getElementById("rotating-word");
      if (el) {
        setInterval(() => {
          el.style.opacity = "0";
          el.style.transform = "translateY(6px)";
          setTimeout(() => {
            idx = (idx + 1) % words.length;
            el.textContent = words[idx];
            el.style.opacity = "1";
            el.style.transform = "translateY(0)";
          }, 250);
        }, 2200);
        el.style.transition = "opacity 0.25s, transform 0.25s";
        el.style.display = "inline-block";
      }
    </script>

    <p class="text-base sm:text-lg text-text-secondary max-w-xl sm:mx-auto mb-9 leading-relaxed reveal stagger-2">
      Development has shifted from writing code to managing agents. The tool for that is the device in your pocket. Marmy is your command center.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-3 sm:justify-center mb-20 reveal stagger-3">
      <a href="#get-started"
        class="inline-flex items-center justify-center gap-2 px-7 py-3 rounded-lg bg-primary hover:bg-primary-hover text-white font-semibold transition-all hover:shadow-lg hover:shadow-primary/20">
        Get Started
      </a>
      <a href="https://github.com/marmy-ai/marmy" target="_blank" rel="noopener"
        class="inline-flex items-center justify-center gap-2 px-7 py-3 rounded-lg border border-border text-text-primary hover:bg-bg-card hover:border-border-light transition-all">
        View Source
      </a>
    </div>

    <!-- Phone mockup -->
    <div class="flex justify-center reveal stagger-4">
      <div class="relative" style="animation: float 6s ease-in-out infinite;">
        <div class="absolute inset-0 scale-90 bg-primary/8 rounded-[3rem] blur-[50px]"></div>
        <div class="relative w-[270px] sm:w-[300px] rounded-[2.5rem] border border-border bg-bg-card p-2 shadow-2xl shadow-black/40">
          <!-- Notch -->
          <div class="flex items-center justify-between px-5 py-1.5">
            <span class="text-[10px] text-text-tertiary font-mono">9:41</span>
            <div class="w-20 h-5 rounded-full bg-bg-deep"></div>
            <div class="flex gap-1 items-center">
              <div class="w-1.5 h-1.5 rounded-full bg-success"></div>
              <span class="text-[10px] text-text-tertiary">LAN</span>
            </div>
          </div>

          <!-- Screen -->
          <div class="rounded-2xl bg-bg-deep overflow-hidden">
            <div class="px-3 py-2 border-b border-border flex items-center justify-between">
              <span class="text-xs font-mono font-bold text-text-primary">Workers</span>
              <span class="text-[10px] font-mono text-text-tertiary">mbp-studio</span>
            </div>

            <div class="p-2 space-y-1.5 font-mono text-[11px]">
              <!-- Manager -->
              <div class="px-2.5 py-2 rounded-lg bg-manager/8 border border-manager/20">
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-1.5">
                    <span class="text-[9px] px-1 py-0.5 rounded bg-manager/20 text-manager font-bold">MGR</span>
                    <span class="text-manager">ralph</span>
                  </div>
                  <div class="w-1.5 h-1.5 rounded-full bg-manager" style="animation: pulse-soft 2s infinite;"></div>
                </div>
                <div class="text-text-tertiary text-[10px] mt-1">Coordinating 3 agents...</div>
              </div>

              <!-- Workers -->
              <div class="px-2.5 py-2 rounded-lg bg-bg-card border border-border">
                <div class="flex items-center justify-between">
                  <span class="text-text-primary">auth-refactor</span>
                  <div class="w-1.5 h-1.5 rounded-full bg-success"></div>
                </div>
                <div class="text-text-tertiary text-[10px] mt-0.5">Migrating session tokens</div>
              </div>

              <div class="px-2.5 py-2 rounded-lg bg-bg-card border border-border">
                <div class="flex items-center justify-between">
                  <span class="text-text-primary">api-tests</span>
                  <div class="w-1.5 h-1.5 rounded-full bg-success"></div>
                </div>
                <div class="text-text-tertiary text-[10px] mt-0.5">12 passing, 2 in progress</div>
              </div>

              <div class="px-2.5 py-2 rounded-lg bg-bg-card border border-secondary/30">
                <div class="flex items-center justify-between">
                  <span class="text-text-primary">frontend-ui</span>
                  <div class="w-1.5 h-1.5 rounded-full bg-secondary"></div>
                </div>
                <div class="text-secondary text-[10px] mt-0.5">Needs your input</div>
              </div>
            </div>

            <div class="flex justify-around py-2 border-t border-border text-[10px] font-mono">
              <span class="text-text-tertiary">Machines</span>
              <span class="text-primary">Workers</span>
              <span class="text-text-tertiary">Terminal</span>
              <span class="text-text-tertiary">Files</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
