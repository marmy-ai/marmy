---
import PhoneFrame from './PhoneFrame.astro';
---

<section class="relative pt-28 pb-24 sm:pt-40 sm:pb-32 px-5 sm:px-8 overflow-hidden">
  <!-- Glow -->
  <div class="absolute top-16 left-1/2 -translate-x-1/2 w-[700px] h-[350px] bg-primary/6 rounded-full blur-[140px] pointer-events-none"></div>
  <div class="absolute top-40 left-1/4 w-[300px] h-[200px] bg-manager/4 rounded-full blur-[100px] pointer-events-none"></div>

  <div class="relative z-10 max-w-5xl mx-auto text-left sm:text-center">
    <p class="font-mono text-xs sm:text-sm text-primary tracking-wider mb-5 reveal">THE MOBILE IDE FOR AI AGENTS</p>

    <h1 class="text-4xl sm:text-5xl lg:text-[3.5rem] font-extrabold tracking-[-0.03em] leading-[1.08] mb-4 reveal stagger-1">
      The future of development fits in your pocket.
    </h1>

    <p class="text-xl sm:text-2xl text-text-secondary max-w-xl sm:mx-auto mb-9 leading-relaxed reveal stagger-2">
      Build with agents. Manage from anywhere.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-3 sm:justify-center mb-4 reveal stagger-3">
      <a href="https://testflight.apple.com/join/v8HmNu1H" target="_blank" rel="noopener"
        class="inline-flex items-center justify-center gap-2 px-7 py-3 rounded-lg bg-primary hover:bg-primary-hover text-white font-semibold transition-all hover:shadow-lg hover:shadow-primary/20">
        Join iOS Beta
      </a>
      <a href="https://github.com/marmy-ai/marmy" target="_blank" rel="noopener"
        class="inline-flex items-center justify-center gap-2 px-7 py-3 rounded-lg border border-border text-text-primary hover:bg-bg-card hover:border-border-light transition-all">
        View Source
      </a>
    </div>
    <p class="text-text-tertiary text-xs sm:text-center mb-16 reveal stagger-3">
      Download the app to get push notifications without configuring APNs yourself.
    </p>

    <!-- Phone + description side by side -->
    <div class="flex flex-col md:flex-row items-center justify-center gap-10 md:gap-16 reveal stagger-4">
      <div class="relative shrink-0">
        <PhoneFrame
          src="/screenshots/workers.png"
          alt="Marmy Workers screen showing active Claude Code sessions"
          class="w-[270px] sm:w-[300px]"
        />
      </div>
      <p class="text-base sm:text-lg text-text-secondary max-w-md text-left leading-relaxed">
        Development has moved from writing code to directing agents. Marmy puts that workflow on your phone. Monitor progress, approve decisions, review files, and talk to your agents by voice. Built for Claude Code, works with any terminal agent.
      </p>
    </div>
  </div>
</section>
