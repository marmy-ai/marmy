<section class="relative pt-28 pb-20 sm:pt-36 sm:pb-28 px-5 sm:px-8 overflow-hidden">
  <!-- Glow -->
  <div class="absolute top-20 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-primary/8 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="relative z-10 max-w-5xl mx-auto text-center">
    <!-- Headline -->
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight leading-[1.1] mb-5 reveal">
      Manage your agent swarm<br/>
      while you <span class="text-primary" id="rotating-verb">run.</span>
    </h1>

    <script>
      const verbs = ["run.", "cook.", "walk.", "commute.", "touch grass."];
      let idx = 0;
      const el = document.getElementById("rotating-verb");
      if (el) {
        setInterval(() => {
          el.style.opacity = "0";
          el.style.transform = "translateY(6px)";
          setTimeout(() => {
            idx = (idx + 1) % verbs.length;
            el.textContent = verbs[idx];
            el.style.opacity = "1";
            el.style.transform = "translateY(0)";
          }, 250);
        }, 2200);
        el.style.transition = "opacity 0.25s, transform 0.25s";
        el.style.display = "inline-block";
      }
    </script>

    <p class="text-base sm:text-lg text-text-secondary max-w-lg mx-auto mb-8 reveal stagger-1">
      A mobile remote control for Claude Code. See the actual work, check in by voice, manage multiple sessions — all from your phone.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-3 justify-center mb-16 reveal stagger-2">
      <a href="#get-started"
        class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg bg-primary hover:bg-primary-hover text-white font-medium transition-colors">
        Get Started
      </a>
      <a href="https://github.com/marmy-ai/marmy" target="_blank" rel="noopener"
        class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg border border-border text-text-primary hover:bg-bg-card transition-colors">
        View Source
      </a>
    </div>

    <!-- Phone mockup -->
    <div class="flex justify-center reveal stagger-3">
      <div class="relative" style="animation: float 6s ease-in-out infinite;">
        <div class="absolute inset-0 scale-90 bg-primary/6 rounded-[3rem] blur-[40px]"></div>
        <div class="relative w-[270px] sm:w-[300px] rounded-[2.5rem] border border-border bg-bg-card p-2 shadow-2xl">
          <!-- Notch -->
          <div class="flex items-center justify-between px-5 py-1.5">
            <span class="text-[10px] text-text-tertiary font-mono">9:41</span>
            <div class="w-20 h-5 rounded-full bg-bg-deep"></div>
            <div class="flex gap-1 items-center">
              <div class="w-1.5 h-1.5 rounded-full bg-success"></div>
              <span class="text-[10px] text-text-tertiary">LAN</span>
            </div>
          </div>

          <!-- Screen -->
          <div class="rounded-2xl bg-bg-deep overflow-hidden">
            <div class="px-3 py-2 border-b border-border flex items-center justify-between">
              <span class="text-xs font-mono font-bold text-text-primary">Workers</span>
              <span class="text-[10px] font-mono text-text-tertiary">mbp-studio</span>
            </div>

            <div class="p-2 space-y-1.5 font-mono text-[11px]">
              <!-- Manager -->
              <div class="px-2.5 py-2 rounded-lg bg-manager/8 border border-manager/20">
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-1.5">
                    <span class="text-[9px] px-1 py-0.5 rounded bg-manager/20 text-manager font-bold">MGR</span>
                    <span class="text-manager">ralph</span>
                  </div>
                  <div class="w-1.5 h-1.5 rounded-full bg-manager" style="animation: pulse-soft 2s infinite;"></div>
                </div>
                <div class="text-text-tertiary text-[10px] mt-1">Monitoring 3 workers...</div>
              </div>

              <!-- Workers -->
              <div class="px-2.5 py-2 rounded-lg bg-bg-card border border-border">
                <div class="flex items-center justify-between">
                  <span class="text-text-primary">auth-refactor</span>
                  <div class="w-1.5 h-1.5 rounded-full bg-success"></div>
                </div>
                <div class="text-text-tertiary text-[10px] mt-0.5">Migrating session tokens</div>
              </div>

              <div class="px-2.5 py-2 rounded-lg bg-bg-card border border-border">
                <div class="flex items-center justify-between">
                  <span class="text-text-primary">api-tests</span>
                  <div class="w-1.5 h-1.5 rounded-full bg-success"></div>
                </div>
                <div class="text-text-tertiary text-[10px] mt-0.5">12 passing, 2 in progress</div>
              </div>

              <div class="px-2.5 py-2 rounded-lg bg-bg-card border border-secondary/30">
                <div class="flex items-center justify-between">
                  <span class="text-text-primary">frontend-ui</span>
                  <div class="w-1.5 h-1.5 rounded-full bg-secondary"></div>
                </div>
                <div class="text-secondary text-[10px] mt-0.5">Needs your input</div>
              </div>
            </div>

            <div class="flex justify-around py-2 border-t border-border text-[10px] font-mono">
              <span class="text-text-tertiary">Machines</span>
              <span class="text-primary">Workers</span>
              <span class="text-text-tertiary">Terminal</span>
              <span class="text-text-tertiary">Files</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
