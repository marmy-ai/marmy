<section class="relative pt-28 pb-24 sm:pt-40 sm:pb-32 px-5 sm:px-8 overflow-hidden">
  <!-- Glow -->
  <div class="absolute top-16 left-1/2 -translate-x-1/2 w-[700px] h-[350px] bg-primary/6 rounded-full blur-[140px] pointer-events-none"></div>
  <div class="absolute top-40 left-1/4 w-[300px] h-[200px] bg-manager/4 rounded-full blur-[100px] pointer-events-none"></div>

  <div class="relative z-10 max-w-5xl mx-auto text-left sm:text-center">
    <p class="font-mono text-xs sm:text-sm text-primary tracking-wider mb-5 reveal">THE MOBILE IDE FOR AI AGENTS</p>

    <h1 class="text-4xl sm:text-5xl lg:text-[3.5rem] font-extrabold tracking-[-0.03em] leading-[1.08] mb-6 reveal stagger-1">
      You are the tech lead.<br/>
      Your agents are your <span class="text-primary" id="rotating-word">team.</span>
    </h1>

    <script>
      const words = ["team.", "fleet.", "workforce.", "engineers."];
      let idx = 0;
      const el = document.getElementById("rotating-word");
      if (el) {
        setInterval(() => {
          el.style.opacity = "0";
          el.style.transform = "translateY(6px)";
          setTimeout(() => {
            idx = (idx + 1) % words.length;
            el.textContent = words[idx];
            el.style.opacity = "1";
            el.style.transform = "translateY(0)";
          }, 250);
        }, 2200);
        el.style.transition = "opacity 0.25s, transform 0.25s";
        el.style.display = "inline-block";
      }
    </script>

    <p class="text-base sm:text-lg text-text-secondary max-w-xl sm:mx-auto mb-9 leading-relaxed reveal stagger-2">
      Development has shifted from writing code to managing agents. The tool for that is the device in your pocket. Marmy is your command center.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-3 sm:justify-center mb-20 reveal stagger-3">
      <a href="#get-started"
        class="inline-flex items-center justify-center gap-2 px-7 py-3 rounded-lg bg-primary hover:bg-primary-hover text-white font-semibold transition-all hover:shadow-lg hover:shadow-primary/20">
        Get Started
      </a>
      <a href="https://github.com/marmy-ai/marmy" target="_blank" rel="noopener"
        class="inline-flex items-center justify-center gap-2 px-7 py-3 rounded-lg border border-border text-text-primary hover:bg-bg-card hover:border-border-light transition-all">
        View Source
      </a>
    </div>

    <!-- Phone screenshot -->
    <div class="flex justify-center reveal stagger-4">
      <div class="relative" style="animation: float 6s ease-in-out infinite;">
        <img
          src="/screenshots/workers.png"
          alt="Marmy Workers screen showing active Claude Code sessions"
          class="relative w-[270px] sm:w-[300px] rounded-3xl"
        />
      </div>
    </div>
  </div>
</section>
