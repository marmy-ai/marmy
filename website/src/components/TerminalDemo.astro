---
import TerminalWindow from './TerminalWindow.astro';
---

<section class="py-20 px-4 sm:px-6 border-t border-border">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl sm:text-4xl font-bold text-center mb-4">
      See the team in action
    </h2>
    <p class="text-text-muted text-center max-w-2xl mx-auto mb-12">
      A lead agent delegates work to sub-agents across machines. You approve when needed.
    </p>

    <TerminalWindow title="marmy — team overview">
      <div class="space-y-2 text-xs sm:text-sm">
        <div class="text-text-muted">
          <span class="text-accent font-bold">team:</span> api-redesign &nbsp; <span class="text-text-muted">·</span> &nbsp; 4 agents &nbsp; <span class="text-text-muted">·</span> &nbsp; 3 machines
        </div>

        <div class="pt-2 border-t border-border mt-2"></div>

        <div>
          <span class="text-accent">lead</span>
          <span class="text-text-muted"> @ work-mbp</span>
          <span class="text-text-muted"> ·</span>
          <span class="text-green"> running</span>
        </div>
        <div class="pl-4 text-text-muted">
          Planning v2 API schema. Delegated 3 tasks to sub-agents.
        </div>

        <div class="pt-1">
          <span class="text-green">  backend</span>
          <span class="text-text-muted"> @ home-server</span>
          <span class="text-text-muted"> ·</span>
          <span class="text-green"> running</span>
        </div>
        <div class="pl-4 text-text-muted">
          Writing src/middleware/rateLimit.ts... <span class="text-text-primary">47 lines</span>
        </div>

        <div class="pt-1">
          <span class="text-green">  tests</span>
          <span class="text-text-muted"> @ home-server</span>
          <span class="text-text-muted"> ·</span>
          <span class="text-[#eab308]"> awaiting approval</span>
        </div>
        <div class="pl-4 text-text-muted">
          Wants to delete __tests__/legacy/ (14 files)
        </div>
        <div class="pl-4 pt-1">
          <span class="text-text-muted">marmy →</span>
          <span class="text-green"> ✓ Approved</span>
          <span class="text-text-muted"> (from iPhone, 3s)</span>
        </div>

        <div class="pt-1">
          <span class="text-green">  frontend</span>
          <span class="text-text-muted"> @ cloud-vm</span>
          <span class="text-text-muted"> ·</span>
          <span class="text-green"> running</span>
        </div>
        <div class="pl-4 text-text-muted">
          Updating dashboard components to match new API schema
        </div>

        <div class="pt-3 border-t border-border mt-2">
          <span class="text-green">✓</span>
          <span class="text-text-primary"> lead:</span>
          <span class="text-text-muted"> All sub-agents complete. Merging changes and running integration tests.</span>
        </div>
      </div>
    </TerminalWindow>
  </div>
</section>
