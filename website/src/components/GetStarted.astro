<section id="get-started" class="py-24 sm:py-32 px-5 sm:px-8 section-divide">
  <div class="max-w-3xl mx-auto">
    <p class="font-mono text-xs text-text-muted uppercase tracking-widest mb-4 text-center reveal">Get started</p>
    <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl italic leading-tight text-center mb-4 reveal stagger-1">
      Three commands. That's it.
    </h2>
    <p class="text-text-secondary text-center max-w-xl mx-auto mb-12 reveal stagger-2">
      From zero to managing your fleet. Repeat for each machine.
    </p>

    <div class="space-y-3 reveal stagger-3">
      <!-- Step 1 -->
      <div class="rounded-xl border border-border bg-bg-card overflow-hidden group">
        <div class="flex items-center justify-between px-4 py-2.5 border-b border-border-subtle">
          <span class="text-xs text-text-muted font-mono">1 &middot; Install</span>
          <button
            class="copy-btn text-xs text-text-muted hover:text-accent transition-colors font-mono"
            data-code="pip install marmy"
          >
            copy
          </button>
        </div>
        <div class="px-4 py-3 font-mono text-sm">
          <span class="text-text-muted">$</span> <span class="text-text-primary">pip install marmy</span>
        </div>
      </div>

      <!-- Step 2 -->
      <div class="rounded-xl border border-border bg-bg-card overflow-hidden group">
        <div class="flex items-center justify-between px-4 py-2.5 border-b border-border-subtle">
          <span class="text-xs text-text-muted font-mono">2 &middot; Start the agent</span>
          <button
            class="copy-btn text-xs text-text-muted hover:text-accent transition-colors font-mono"
            data-code="marmy start"
          >
            copy
          </button>
        </div>
        <div class="px-4 py-3 font-mono text-sm">
          <span class="text-text-muted">$</span> <span class="text-text-primary">marmy start</span>
        </div>
      </div>

      <!-- Step 3 -->
      <div class="rounded-xl border border-border bg-bg-card overflow-hidden group">
        <div class="flex items-center justify-between px-4 py-2.5 border-b border-border-subtle">
          <span class="text-xs text-text-muted font-mono">3 &middot; Pair your phone</span>
          <button
            class="copy-btn text-xs text-text-muted hover:text-accent transition-colors font-mono"
            data-code="marmy pair"
          >
            copy
          </button>
        </div>
        <div class="px-4 py-3 font-mono text-sm">
          <span class="text-text-muted">$</span> <span class="text-text-primary">marmy pair</span>
          <div class="text-text-muted mt-1.5 text-xs">
            Pairing code: <span class="text-accent">XXXX-XXXX</span>
          </div>
          <div class="text-text-muted text-xs">
            Scan the QR code in the marmy app, or enter the code manually.
          </div>
        </div>
      </div>

      <!-- Step 4 -->
      <div class="rounded-xl border border-accent/20 bg-accent/5 overflow-hidden">
        <div class="flex items-center justify-between px-4 py-2.5 border-b border-accent/10">
          <span class="text-xs text-accent font-mono">4 &middot; Use Claude Code like normal</span>
        </div>
        <div class="px-4 py-3 font-mono text-sm">
          <span class="text-text-muted">$</span> <span class="text-text-primary">claude "refactor the auth module"</span>
          <div class="mt-1.5 text-xs">
            <span class="text-accent">&#9679;</span>
            <span class="text-text-muted"> marmy picks up the session automatically</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const code = btn.getAttribute('data-code');
      if (!code) return;
      await navigator.clipboard.writeText(code);
      const original = btn.textContent;
      btn.textContent = 'copied!';
      setTimeout(() => {
        btn.textContent = original;
      }, 2000);
    });
  });
</script>
