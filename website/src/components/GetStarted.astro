<section id="get-started" class="py-20 sm:py-28 px-5 sm:px-8 border-t border-border">
  <div class="max-w-2xl mx-auto">
    <h2 class="text-2xl sm:text-3xl font-bold text-center mb-8 reveal">
      Three commands. <span class="text-primary">That's it.</span>
    </h2>

    <div class="space-y-3 reveal stagger-1">
      <div class="rounded-xl border border-border bg-bg-card overflow-hidden">
        <div class="flex items-center justify-between px-4 py-2 border-b border-border">
          <span class="text-xs text-text-tertiary font-mono">1 · Install</span>
          <button class="copy-btn text-xs text-text-tertiary hover:text-primary transition-colors font-mono" data-code="curl -fsSL https://marmy.ai/install.sh | bash">copy</button>
        </div>
        <div class="px-4 py-2.5 font-mono text-sm">
          <span class="text-text-tertiary">$</span> <span class="text-text-primary">curl -fsSL https://marmy.ai/install.sh | bash</span>
        </div>
      </div>

      <div class="rounded-xl border border-border bg-bg-card overflow-hidden">
        <div class="flex items-center justify-between px-4 py-2 border-b border-border">
          <span class="text-xs text-text-tertiary font-mono">2 · Start</span>
          <button class="copy-btn text-xs text-text-tertiary hover:text-primary transition-colors font-mono" data-code="marmy-agent serve">copy</button>
        </div>
        <div class="px-4 py-2.5 font-mono text-sm">
          <span class="text-text-tertiary">$</span> <span class="text-text-primary">marmy-agent serve</span>
        </div>
      </div>

      <div class="rounded-xl border border-border bg-bg-card overflow-hidden">
        <div class="flex items-center justify-between px-4 py-2 border-b border-border">
          <span class="text-xs text-text-tertiary font-mono">3 · Pair</span>
          <button class="copy-btn text-xs text-text-tertiary hover:text-primary transition-colors font-mono" data-code="marmy-agent pair">copy</button>
        </div>
        <div class="px-4 py-2.5 font-mono text-sm">
          <span class="text-text-tertiary">$</span> <span class="text-text-primary">marmy-agent pair</span>
          <div class="text-text-tertiary mt-1 text-xs">Token: <span class="text-secondary">a1b2c3d4e5f6...</span></div>
        </div>
      </div>

      <div class="rounded-xl border border-primary/20 bg-primary/5 overflow-hidden">
        <div class="px-4 py-2 border-b border-primary/10">
          <span class="text-xs text-primary font-mono">4 · Use Claude Code like normal</span>
        </div>
        <div class="px-4 py-2.5 font-mono text-sm">
          <span class="text-text-tertiary">$</span> <span class="text-text-primary">claude "refactor the auth module"</span>
          <div class="mt-1 text-xs"><span class="text-success">&#9679;</span> <span class="text-text-tertiary">marmy picks it up automatically</span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const code = btn.getAttribute('data-code');
      if (!code) return;
      await navigator.clipboard.writeText(code);
      const original = btn.textContent;
      btn.textContent = 'copied!';
      setTimeout(() => { btn.textContent = original; }, 2000);
    });
  });
</script>
