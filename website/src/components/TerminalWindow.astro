---
interface Props {
  title?: string;
  class?: string;
}

const { title = "terminal", class: className = "" } = Astro.props;
---

<div class:list={["rounded-xl border border-border overflow-hidden", className]}>
  <div class="flex items-center gap-2 px-4 py-2 bg-bg-card border-b border-border">
    <div class="flex gap-1.5">
      <div class="w-2.5 h-2.5 rounded-full bg-error"></div>
      <div class="w-2.5 h-2.5 rounded-full bg-secondary"></div>
      <div class="w-2.5 h-2.5 rounded-full bg-success"></div>
    </div>
    <span class="text-text-tertiary text-xs font-mono ml-2">{title}</span>
  </div>
  <div class="bg-bg-deep p-4 font-mono text-sm leading-relaxed overflow-x-auto">
    <slot />
  </div>
</div>
