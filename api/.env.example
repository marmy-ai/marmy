# Required: Auth token must match the agent's config.toml [auth] token
MARMY_AUTH_TOKEN=YOUR_AUTH_TOKEN_HERE

# Optional: Server settings (defaults shown)
# MARMY_HOST=0.0.0.0
# MARMY_PORT=3000

# Optional: Workspace path for file browsing
# MARMY_WORKSPACE_PATH=/path/to/your/workspace

# Optional: Number of tmux history lines to capture
# MARMY_TMUX_CAPTURE_LINES=2000

# Optional: Claude CLI command override
# MARMY_CLAUDE_COMMAND=claude

# Optional: Log level (debug, info, warn, error)
# LOG_LEVEL=info
